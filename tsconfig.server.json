{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist-server",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": ["server/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["**/*.test.ts", "dist", "dist-server", "node_modules"]
}
