{
  "name": "huskyhac",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "server:dev": "tsx watch server/index.ts",
    "server:build": "tsc -p tsconfig.server.json",
    "server:start": "node dist-server/server/index.js",
    "build": "tsc -b && vite build --config vite.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vite.config.ts",
    "test:watch": "vitest --config vite.config.ts",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run server:build && npm run test && npm run build"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-globe.gl": "^2.27.3",
    "react-router-dom": "^6.26.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
